HINTERLAND_ENV=local
HINTERLAND_LOG_LEVEL=INFO
HINTERLAND_CORS_ORIGINS=["http://localhost:19006"]
HINTERLAND_PHOTOS_BUCKET=photos
HINTERLAND_BLOB_ACCOUNT_ENDPOINT=
HINTERLAND_DATABASE_HOST=localhost
HINTERLAND_DATABASE_PORT=5432
HINTERLAND_DATABASE_NAME=hinterland
HINTERLAND_DATABASE_USER=hinterland
HINTERLAND_DATABASE_PASSWORD=hinterland
HINTERLAND_DATABASE_PASSWORD_SECRET=
HINTERLAND_DATABASE_POOL_SIZE=5
HINTERLAND_DATABASE_MAX_OVERFLOW=2
HINTERLAND_DATABASE_ECHO_SQL=false
HINTERLAND_READINESS_DATABASE_REQUIRED=false

# Local/dev-only login bypass for device development. Never enable in prod.
HINTERLAND_DEV_AUTH_ENABLED=false
HINTERLAND_DEV_AUTH_TOKEN=hinterland-dev-bypass
HINTERLAND_DEV_AUTH_DISPLAY_NAME="Dev Explorer"
